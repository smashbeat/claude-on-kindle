# Cloudflare Tunnel connector token (Zero Trust dashboard -> Networks -> Tunnels ->
# your tunnel). Read by cloudflared. KEEP SECRET — never commit the real value.
TUNNEL_TOKEN=

# App config (optional; defaults shown)
KT_SESSION=claude
KT_HOST=127.0.0.1
KT_PORT=8882
# Mark the CSRF cookie Secure (set when served over HTTPS):
# KT_SECURE=1

# Optional defense-in-depth: require a secret header that only your trusted proxy
# injects, so a process reaching the port directly (a co-located container) is rejected.
# Set the SAME header+value as a proxy rule (e.g. Cloudflare: Rules -> Transform Rules
# -> Modify Request Header -> Set static). Leave unset to disable.
# KT_AUTH_HEADER=X-KT-Auth
# KT_AUTH_SECRET=

